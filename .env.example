# Resend (required for contact form email delivery)
# Create an API key at https://resend.com/api-keys
RESEND_API_KEY=

# Contact form addresses (optional — defaults shown)
# FROM must be on a domain verified in Resend
CONTACT_FROM_EMAIL="Green Expert <contact@greenexpert.ma>"
CONTACT_TO_EMAIL=said@greenexpert.ma

# Public site URL used in email templates (links back to the site)
NEXT_PUBLIC_BASE_URL=https://greenexpert.ma
